# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg-compatible PostgreSQL URL (note: postgresql+asyncpg:// prefix)
POSTGRES_URL=postgresql+asyncpg://moviematch:changeme@localhost:5432/moviematch

# ── Cache & Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# MUST change in production. Generate: openssl rand -hex 32
SECRET_KEY=insecure-dev-secret-CHANGE-IN-PRODUCTION-minimum-32-chars

# ── External APIs ─────────────────────────────────────────────────────────────
# Free registration at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── ML Service URLs ───────────────────────────────────────────────────────────
ML_RECSYS_URL=http://localhost:8001
ML_NLP_URL=http://localhost:8002
ML_CV_URL=http://localhost:8003

# ── MLflow ───────────────────────────────────────────────────────────────────
# optional: set to remote MLflow server URL in production
MLFLOW_TRACKING_URI=./mlruns

# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (must start with NEXT_PUBLIC_ to be exposed to browser) ─────────
NEXT_PUBLIC_API_URL=http://localhost:8000
