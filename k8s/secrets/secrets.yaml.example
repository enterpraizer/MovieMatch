# NEVER commit real values to git. This is a template only.
#
# Generate with:
#   kubectl create secret generic moviematch-secrets \
#     --namespace=moviematch \
#     --from-literal=POSTGRES_URL='postgresql+asyncpg://...' \
#     --from-literal=REDIS_URL='redis://...' \
#     --from-literal=SECRET_KEY="$(openssl rand -hex 32)" \
#     --from-literal=TMDB_API_KEY='your_tmdb_key'
#
# Or use sealed-secrets / external-secrets / HashiCorp Vault in production.
---
apiVersion: v1
kind: Secret
metadata:
  name: moviematch-secrets
  namespace: moviematch
type: Opaque
stringData:
  POSTGRES_URL: "postgresql+asyncpg://moviematch:REPLACE_ME@postgres.moviematch.svc.cluster.local:5432/moviematch"
  REDIS_URL: "redis://redis.moviematch.svc.cluster.local:6379/0"
  SECRET_KEY: "REPLACE_WITH_openssl_rand_hex_32"
  TMDB_API_KEY: "REPLACE_WITH_TMDB_KEY"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: moviematch-config
  namespace: moviematch
data:
  LOG_LEVEL: "INFO"
  ALLOWED_ORIGINS: "https://moviematch.example.com"
  ML_RECSYS_URL: "http://moviematch-ml-recsys.moviematch.svc.cluster.local:8001"
  ML_NLP_URL: "http://moviematch-ml-nlp.moviematch.svc.cluster.local:8002"
  ML_CV_URL: "http://moviematch-ml-cv.moviematch.svc.cluster.local:8003"
  MLFLOW_TRACKING_URI: "http://mlflow.moviematch.svc.cluster.local:5000"
  PUBLIC_API_URL: "https://moviematch.example.com"
